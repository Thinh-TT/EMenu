<section class="auth-shell">
    <div class="auth-card">
        <div class="auth-panel">
            <span class="eyebrow">Secure access</span>
            <h2>Login</h2>
            <p>Sign in to manage tables, orders, kitchen flow and restaurant operations from one place.</p>
            <ul>
                <li>Bright, simple layout for daily staff usage</li>
                <li>Fast access to dashboard, tables, menu and billing</li>
                <li>Same workflow for admin and staff roles</li>
            </ul>
        </div>

        <form method="post" class="auth-form">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label>Username</label>
                <input name="username" class="form-control" />
            </div>

            <div class="form-group">
                <label>Password</label>
                <input type="password" name="password" class="form-control" />
            </div>

            <button class="btn btn-primary">Login</button>

            @if (ViewBag.Error != null)
            {
                <p class="text-danger mt-3">@ViewBag.Error</p>
            }
        </form>
    </div>
</section>
