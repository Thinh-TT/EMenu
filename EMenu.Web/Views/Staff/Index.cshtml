<h2>Staff Management</h2>

<a href="/Staff/Create" class="btn btn-primary">Add Staff</a>

<table class="table">

	<thead>
		<tr>
			<th>ID</th>
			<th>Name</th>
			<th>Phone</th>
			<th>Email</th>
			<th>Account</th>
			<th>Actions</th>
		</tr>
	</thead>

	<tbody>

		@foreach (var item in Model)
		{
			<tr>

				<td>@item.StaffID</td>

				<td>@item.StaffName</td>

				<td>@item.Phone</td>

				<td>@item.Email</td>

				<td>@item.User?.UserName</td>

				<td>

					<a href="/Staff/Edit/@item.StaffID">Edit</a> |

					<a href="/Staff/Delete/@item.StaffID">Delete</a>

				</td>

			</tr>
		}

	</tbody>

</table>