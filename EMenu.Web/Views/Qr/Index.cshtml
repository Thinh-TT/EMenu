<section class="qr-stage">
    <h2>QR Codes for Tables</h2>
    <p>Generate and print table QR codes from a cleaner grid that is easier to scan and manage.</p>

    <div class="qr-grid">
        @for (int i = 1; i <= 10; i++)
        {
            <div class="qr-box">
                <h3>Table @i</h3>
                <img src="/Qr/Table?tableId=@i&t=@DateTime.Now.Ticks" alt="QR Table @i" />
                <p>/Customer/Start?tableId=@i</p>
            </div>
        }
    </div>
</section>
