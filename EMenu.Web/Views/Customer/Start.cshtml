<h2>Welcome</h2>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">
        @ViewBag.Error
    </div>
}

<form method="post">
    @Html.AntiForgeryToken()

    <input type="hidden"
           name="tableId"
           value="@ViewBag.TableId" />

    <div class="mb-3">
        <label>Your Name *</label>
        <input name="name"
               class="form-control"
               required />
    </div>

    <div class="mb-3">
        <label>Phone (optional)</label>
        <input name="phone"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Email (optional)</label>
        <input name="email"
               class="form-control" />
    </div>

    <button class="btn btn-primary">
        Start Order
    </button>
</form>
