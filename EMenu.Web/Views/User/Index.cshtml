@model List<EMenu.Domain.Entities.User>
@using System.Linq

<h2>User Management</h2>

<a href="/User/Create" class="btn btn-primary">Create User</a>

<table class="table">
	<thead>
		<tr>
			<th>ID</th>
			<th>Username</th>
			<th>Role</th>
			<th>Status</th>
			<th>Actions</th>
		</tr>
	</thead>

	<tbody>
		@foreach (var user in Model)
		{
			<tr>
				<td>@user.UserID</td>
				<td>@user.UserName</td>
				<td>@user.UserRoles.FirstOrDefault()?.Role?.RoleName</td>
				<td>@(user.IsActive ? "Active" : "Disabled")</td>
				<td class="table-actions">
					<a class="table-action-link" href="/User/Edit/@user.UserID">Edit</a>
					<form asp-action="ToggleStatus"
					      asp-route-id="@user.UserID"
					      method="post"
					      class="table-action-form">
						<button type="submit"
						        class="btn btn-link table-action-link">
							Toggle Status
						</button>
					</form>
				</td>
			</tr>
		}
	</tbody>
</table>
